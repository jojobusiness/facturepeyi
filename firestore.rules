rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Utilitaire : vérifie si l'utilisateur est authentifié
    function isAuth() {
      return request.auth != null;
    }

    // Utilitaire : récupère le doc utilisateur
    function getUserData() {
      return get(/databases/$(database)/documents/utilisateurs/$(request.auth.uid)).data;
    }

    // Utilitaire : vérifie si l'utilisateur appartient à une entreprise
    function isMembreEntreprise(entrepriseId) {
      return isAuth() &&
        exists(/databases/$(database)/documents/entreprises/$(entrepriseId)/membres/$(request.auth.uid));
    }

    // Utilitaire : vérifie si l'utilisateur a l'un des rôles donnés
    function hasRole(entrepriseId, roles) {
      return isAuth() &&
        get(/databases/$(database)/documents/entreprises/$(entrepriseId)/membres/$(request.auth.uid)).data.role in roles;
    }

    // ── Profils utilisateurs ──────────────────────────────────────────────────
    match /utilisateurs/{uid} {
      allow read: if isAuth() && request.auth.uid == uid;
      allow create: if isAuth() && request.auth.uid == uid;
      allow update: if isAuth() && request.auth.uid == uid;
    }

    // ── Liens de paiement (portail client) ───────────────────────────────────
    match /paymentLinks/{token} {
      // Seuls les utilisateurs authentifiés peuvent créer un lien
      allow create: if isAuth();
      // Lecture réservée au créateur (le serveur Admin SDK lit sans restriction)
      allow read: if isAuth() && resource.data.createdBy == request.auth.uid;
    }

    // ── Entreprises ───────────────────────────────────────────────────────────
    match /entreprises/{entrepriseId} {
      allow read: if isMembreEntreprise(entrepriseId);
      allow create: if isAuth();
      allow update: if hasRole(entrepriseId, ['admin']);
      allow delete: if hasRole(entrepriseId, ['admin']);

      // Membres : lecture pour tous les membres, gestion pour les admins
      match /membres/{uid} {
        allow read: if isMembreEntreprise(entrepriseId);
        allow write: if hasRole(entrepriseId, ['admin']);
        // L'admin peut s'ajouter lui-même lors de l'inscription
        allow create: if isAuth() && request.auth.uid == uid;
      }

      // Factures
      match /factures/{facId} {
        allow read: if isMembreEntreprise(entrepriseId);
        allow create: if hasRole(entrepriseId, ['admin', 'comptable', 'employe']);
        allow update: if hasRole(entrepriseId, ['admin', 'comptable']);
        allow delete: if hasRole(entrepriseId, ['admin']);
      }

      // Clients
      match /clients/{clientId} {
        allow read: if isMembreEntreprise(entrepriseId);
        allow create: if hasRole(entrepriseId, ['admin', 'comptable', 'employe']);
        allow update: if hasRole(entrepriseId, ['admin', 'comptable']);
        allow delete: if hasRole(entrepriseId, ['admin']);
      }

      // Dépenses
      match /depenses/{depenseId} {
        allow read: if isMembreEntreprise(entrepriseId);
        allow create: if hasRole(entrepriseId, ['admin', 'comptable', 'employe']);
        allow update: if hasRole(entrepriseId, ['admin', 'comptable']);
        allow delete: if hasRole(entrepriseId, ['admin']);
      }

      // Catégories
      match /categories/{catId} {
        allow read: if isMembreEntreprise(entrepriseId);
        allow write: if hasRole(entrepriseId, ['admin', 'comptable']);
      }

      // Plan comptable
      match /comptes/{compteId} {
        allow read: if isMembreEntreprise(entrepriseId);
        allow write: if hasRole(entrepriseId, ['admin', 'comptable']);
      }
    }
  }
}
